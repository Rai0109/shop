# ============================================
# XELLOXX SHOP — Environment Variables
# Copy file này thành .env để chạy local
# Trên Railway: thêm vào tab Variables
# ============================================

# ===== BẮT BUỘC =====
# Tạo bằng: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_random_64_chars_string_very_important

# Secret để sign download links (chống share link)
DOWNLOAD_SECRET=change_this_to_another_random_64_chars_string

# ===== LƯU TRỮ (Railway Volume) =====
# Mount Volume tại /data trên Railway, sau đó set biến này
DATA_DIR=/data

# ===== MB BANK (tùy chọn) =====
# Dùng tài khoản phụ riêng, không dùng TK chính!
MB_USERNAME=
MB_PASSWORD=
MB_ACCOUNT=

# ===== SERVER =====
# Railway tự set PORT, không cần đặt thủ công
# PORT=8000

# ===== FILE UPLOAD (tùy chọn) =====
# Thư mục upload (mặc định: ./uploads - cần Volume để persistent)
# UPLOAD_DIR=/data/uploads

# Giới hạn kích thước file (MB)
MAX_IMAGE_MB=10
MAX_FILE_MB=200
